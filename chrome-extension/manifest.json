{
  "manifest_version": 3,
  "name": "SiteCheckAI Recorder",
  "version": "1.0.0",
  "description": "Zeichnet Nutzer-Interaktionen auf und generiert automatisierte Playwright-Tests",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SiteCheckAI Recorder"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["<all_urls>"]
}